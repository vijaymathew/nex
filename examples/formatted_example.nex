class BankAccount
feature
  balance: Integer
  owner: String
  get_balance(): Integer do
      balance()
  end
  deposit(amount: Integer) do
      balance := balance + amount
  end

private feature
  internal_id: String
  generate_id() do
      print("Generating ID")
  end

-> Bank, Auditor feature
  audit_log: String
  get_audit(): String do
      audit_log()
  end

create
  make(initial: Integer, name: String) do
      balance := initial
      owner := name
      internal_id := "ID-001"
      audit_log := "Created"
  end
invariant
  positive_balance: nil
  has_owner: nil
end
