class BankAccount
feature
  balance: Integer
  owner: String

  get_balance(): Integer do
      result := balance
  end

  deposit(amount: Integer) do
      balance := balance + amount
  end

private feature
  internal_id: String

  generate_id() do
      print("Generating ID")
  end

feature
  audit_log: String

  get_audit(): String do
      result := audit_log
  end

create
  make(initial: Integer, name: String) do
      balance := initial
      owner := name
      internal_id := "ID-001"
      audit_log := "Created"
  end

invariant
  non_negative: balance >= 0
end
