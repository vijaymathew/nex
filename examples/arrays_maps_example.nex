-- Arrays and Maps Example
--
-- Collection types and the literal syntax for them:
--
--   Array [Integer]                [1, 2, 3]
--   Map [String, Real]             {"apple": 1.50}
--   Array [Array [Integer]]        [[1, 2], [3, 4]]
--   Map [String, Array [Integer]]  {"Alice": [95, 87]}
--
-- Elements come out with get(); arrays grow with add().
--
-- Run:  nex arrays_maps_example.nex

class NumberList
  feature
    numbers: Array [Integer]

  create
    make() do
      numbers := [1, 2, 3, 4, 5]
    end

  feature
    get_at(index: Integer): Integer do
      result := numbers.get(index)
    end

    sum(): Integer do
      result := 0
      from
        let i: Integer := 0
      until
        i >= numbers.length
      do
        result := result + numbers.get(i)
        i := i + 1
      end
    end

    to_text(): String do
      result := ""
      from
        let i: Integer := 0
      until
        i >= numbers.length
      do
        if i > 0 then
          result := result + ", "
        end
        result := result + numbers.get(i).to_string
        i := i + 1
      end
    end
end

class Store
  feature
    items: Array [String]
    prices: Map [String, Real]
    inventory: Map [String, Integer]

  create
    make() do
      items := ["apple", "banana", "orange"]
      prices := {"apple": 1.50, "banana": 0.75, "orange": 1.25}
      inventory := {"apple": 10, "banana": 15, "orange": 8}
    end

  feature
    price_of(item: String): Real do
      result := prices.get(item)
    end

    show_inventory(c: Console) do
      from
        let i: Integer := 0
      until
        i >= items.length
      do
        let item: String := items.get(i)
        c.print_line("    " + item + ": $" + prices.get(item).to_string +
                     " (" + inventory.get(item).to_string + " in stock)")
        i := i + 1
      end
    end

    total_value(): Real do
      result := 0.0
      from
        let i: Integer := 0
      until
        i >= items.length
      do
        let item: String := items.get(i)
        result := result + prices.get(item) * inventory.get(item)
        i := i + 1
      end
    end
end

-- An array of arrays: the outer get() yields a row, the inner a cell.
class Grid
  feature
    matrix: Array [Array [Integer]]

  create
    make() do
      matrix := [
        [1, 2, 3],
        [4, 5, 6],
        [7, 8, 9]
      ]
    end

  feature
    cell(row, col: Integer): Integer do
      result := matrix.get(row).get(col)
    end

    show(c: Console) do
      from
        let r: Integer := 0
      until
        r >= matrix.length
      do
        let row: Array [Integer] := matrix.get(r)
        let line: String := "   "
        from
          let k: Integer := 0
        until
          k >= row.length
        do
          line := line + " " + row.get(k).to_string
          k := k + 1
        end
        c.print_line(line)
        r := r + 1
      end
    end
end

-- A map whose values are arrays.
class StudentGrades
  feature
    grades: Map [String, Array [Integer]]

  create
    make() do
      grades := {
        "Alice": [95, 87, 92],
        "Bob": [78, 85, 90],
        "Charlie": [88, 91, 85]
      }
    end

  feature
    score(student: String, test: Integer): Integer do
      result := grades.get(student).get(test)
    end

    average(student: String): Real do
      let tests: Array [Integer] := grades.get(student)
      let total: Integer := 0
      from
        let i: Integer := 0
      until
        i >= tests.length
      do
        total := total + tests.get(i)
        i := i + 1
      end
      -- Integer / Integer truncates, so widen one side to get a Real.
      result := total * 1.0 / tests.length
    end
end

function main() do
  let c: Console := create Console

  c.print_line("1. Array [Integer]")
  let numbers: NumberList := create NumberList.make
  c.print_line("    contents  = " + numbers.to_text)
  c.print_line("    get(2)    = " + numbers.get_at(2).to_string)
  c.print_line("    sum       = " + numbers.sum.to_string)

  c.print_line("2. Map [String, Real] and Map [String, Integer]")
  let store: Store := create Store.make
  store.show_inventory(c)
  c.print_line("    price of a banana = $" + store.price_of("banana").to_string)
  c.print_line("    total value       = $" + store.total_value.to_string)

  c.print_line("3. Array [Array [Integer]]")
  let grid: Grid := create Grid.make
  grid.show(c)
  c.print_line("    cell(1, 2) = " + grid.cell(1, 2).to_string)

  c.print_line("4. Map [String, Array [Integer]]")
  let sg: StudentGrades := create StudentGrades.make
  c.print_line("    Alice's second test = " + sg.score("Alice", 1).to_string)
  c.print_line("    Alice's average     = " + sg.average("Alice").to_string)
  c.print_line("    Bob's average       = " + sg.average("Bob").to_string)
end

main()
