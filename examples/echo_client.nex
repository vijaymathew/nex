intern net/Tcp_Socket

class Echo_Client
  note "A small client that talks to examples/echo_server.nex using the JVM-only net libraries."

create
  make(host: String, port: Integer, message: String) do
    let client: Tcp_Socket := create Tcp_Socket.make(host, port)
    if client.connect(1000) then
      client.send_line(message)
      print(client.read_line())
      client.close()
    else
      print("Connection failed or timed out.")
    end
  end
end
