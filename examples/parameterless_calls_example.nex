-- Parameterless Calls Example
--
-- A feature that takes no arguments is called without parentheses:
-- `counter.increment`, not `counter.increment()`. Declarations still write
-- the empty list -- `increment() do ... end` -- so the call site reads like
-- an attribute access whether the name is stored or computed. That is the
-- point: a caller cannot tell a field from a parameterless function, so a
-- class can switch one for the other without touching its clients.
--
-- Run:  nex parameterless_calls_example.nex

class Point
  private feature
    x: Integer
    y: Integer

  create
    make(newx, newy: Integer) do
      x := newx
      y := newy
    end

  feature
    -- Declared with (), called without.
    get_x(): Integer do
      result := x
    end

    get_y(): Integer do
      result := y
    end

    reset() do
      x := 0
      y := 0
    end

    to_text(): String do
      result := "Point(" + x.to_string + ", " + y.to_string + ")"
    end
end

class Counter
  create
    make() do
      count := 0
    end

  feature
    count: Integer

    increment() do
      count := count + 1
    end

    decrement() do
      count := count - 1
    end

    reset() do
      count := 0
    end
end

class Account
  create
    make(owner: String, initial: Integer) do
      name := owner
      balance := initial
    end

  feature
    balance: Integer
    name: String

    -- Inside a class, a parameterless call on the current object drops the
    -- target as well: `show_name`, not `self.show_name()`.
    show_all(c: Console) do
      show_name(c)
      show_balance(c)
    end

    show_name(c: Console) do
      c.print_line("    owner:   " + name)
    end

    show_balance(c: Console) do
      c.print_line("    balance: " + balance.to_string)
    end

    deposit(amount: Integer)
      require
        positive: amount > 0
      do
        balance := balance + amount
      end

    withdraw(amount: Integer)
      require
        positive: amount > 0
        sufficient: balance >= amount
      do
        balance := balance - amount
      end
end

function main() do
  let c: Console := create Console

  -- 1. Parameterless queries read like fields.
  c.print_line("1. queries")
  let p: Point := create Point.make(3, 4)
  c.print_line("  " + p.to_text + " -- x = " + p.get_x.to_string +
               ", y = " + p.get_y.to_string)

  -- 2. Parameterless commands, same shape.
  c.print_line("2. commands")
  p.reset
  c.print_line("  after reset: " + p.to_text)

  let counter: Counter := create Counter.make
  counter.increment
  counter.increment
  counter.increment
  counter.decrement
  c.print_line("  counter after 3 increments and 1 decrement: " +
               counter.count.to_string)
  counter.reset
  c.print_line("  after reset: " + counter.count.to_string)

  -- 3. `count` above is a stored field and `get_x` is computed, yet both are
  --    reached the same way. That uniformity is what lets a class replace one
  --    with the other later without breaking any caller.
  c.print_line("3. fields and functions are called alike")
  let a: Account := create Account.make("Grace", 500)
  a.show_all(c)
  a.deposit(250)
  a.withdraw(100)
  c.print_line("  after deposit(250) and withdraw(100):")
  a.show_all(c)
end

main()
