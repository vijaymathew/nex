-- ============================================================================
-- Studio 2, Level 2 — Cross-System Model Consistency
--
-- Redesigns all three systems (delivery, knowledge, world) and, for each, runs a
-- "before vs after" pair: the Studio 1 flat operation that admits a silent bug,
-- then the V2 model that makes that bug unrepresentable.
--
-- Run from this directory:  nex studio_2_level2.nex
--
-- V2 models are pulled in with intern; the Studio 1 flat classes are defined
-- inline below so the "before" half is runnable in the same program.
-- ============================================================================

intern Delivery_Task
intern Document
intern World_Object

-- ----- Studio 1 flat models (the "before"), copied verbatim for comparison ----

class Delivery_Tiny
feature
  next_stop(current, destination: String): String
    require
      current_non_empty: current /= ""
      destination_non_empty: destination /= ""
    do
      if current = destination then
        result := current
      elseif current = "A" and destination = "C" then
        result := "B"
      elseif current = "B" and destination = "C" then
        result := "C"
      else
        result := "UNREACHABLE"
      end
    ensure
      decision_returned: result /= ""
    end
end

class Notes_Tiny
feature
  find_by_tag(tag: String): String
    require
      tag_non_empty: tag /= ""
    do
      if tag = "algorithms" then
        result := "note_001"
      elseif tag = "graphs" then
        result := "note_002"
      else
        result := "NOT_FOUND"
      end
    ensure
      response_non_empty: result /= ""
    end
end

class World_Tiny
feature
  step(position, velocity, max_x: Integer): Integer
    require
      max_positive: max_x > 0
    do
      let next: Integer := position + velocity
      if next < 0 then
        result := 0
      elseif next > max_x then
        result := max_x
      else
        result := next
      end
    ensure
      bounded: result >= 0 and result <= max_x
    end
end

function main() do
  -- ========================================================================
  -- DELIVERY: before — failure is an in-band magic string the caller may use
  --           as if it were a real stop.        after — illegal states blocked.
  -- ========================================================================
  print("### DELIVERY ###")
  let flat_d: Delivery_Tiny := create Delivery_Tiny
  print("before: next_stop(\"X\",\"C\") = " + flat_d.next_stop("X", "C"))  -- "UNREACHABLE"
  print("        ^ a String, indistinguishable from a real stop name")

  let r: Route := create Route.make("RT-AC", ["A", "B", "C"])
  let task: Delivery_Task := create Delivery_Task.pending("T001", r)
  do
    task.advance()                 -- still PENDING (never assigned)
    print("after:  BUG — moved an unassigned task")
  rescue
    print("after:  blocked — " + exception + " (an unassigned task cannot move)")
  end

  -- ========================================================================
  -- KNOWLEDGE: before — "NOT_FOUND" sentinel shares the String type with real
  --            note ids.   after — real entities + a link that cannot be invalid.
  -- ========================================================================
  print("### KNOWLEDGE ###")
  let flat_n: Notes_Tiny := create Notes_Tiny
  print("before: find_by_tag(\"unknown\") = " + flat_n.find_by_tag("unknown")) -- "NOT_FOUND"
  print("        ^ in-band failure; same type as find_by_tag(\"graphs\") = " + flat_n.find_by_tag("graphs"))

  let good: Doc_Link := create Doc_Link.make("D1", "D2", "references")
  print("after:  valid link D1->D2 references, is_valid = " + good.is_valid())
  do
    let bad: Doc_Link := create Doc_Link.make("D1", "D1", "references")
    print("after:  BUG — built a self-link")
  rescue
    print("after:  blocked — " + exception + " (a document cannot link to itself)")
  end

  -- ========================================================================
  -- WORLD: before — an already-out-of-bounds position is silently clamped, so
  --        the bug is invisible.   after — such an object cannot be created.
  -- ========================================================================
  print("### WORLD ###")
  let flat_w: World_Tiny := create World_Tiny
  print("before: step(-5, 0, 10) = " + flat_w.step(-5, 0, 10) + "  (invalid input -5 silently became 0)")

  do
    let obj: World_Object := create World_Object.make("o1", -5, 0, 10)
    print("after:  BUG — created an out-of-bounds object")
  rescue
    print("after:  blocked — " + exception + " (cannot place an object out of bounds)")
  end
end

main()
