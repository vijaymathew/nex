-- Turtle Graphics: Draw a colorful square.

function turtle(title: String): Turtle
do
  let win: Window := create Window.with_title(title)
  win.show()

  let t := create Turtle.on_window(win)
  t.speed(6)
  t.pensize(3)
  result := t
end

function square(t: Turtle): Turtle
do
  -- Draw a square with different colors on each side
  t.color("red")
  t.forward(100)
  t.right(90)

  t.color("blue")
  t.forward(100)
  t.right(90)

  t.color("green")
  t.forward(100)
  t.right(90)

  t.color("orange")
  t.forward(100)
  t.right(90)

  result := t
end

function polygon(t: Turtle, n: Integer, length: Integer): Turtle
do
  let angle := 360 / n
  from let i := 0 until i = n do
    t.forward(length)
    t.left(angle)
    i := i + 1
  end
  result := t
end

function circle(t: Turtle, radius: Integer): Turtle
do
  let circumference := 2 * 3.14159265359 * radius
  let n := 30
  let length := circumference / n
  polygon(t, n, length)
  result := t
end

