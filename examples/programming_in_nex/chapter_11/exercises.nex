-- ============================================================================
-- Programming with Nex — Chapter 11: Nested and Composite Structures
-- Solutions to the end-of-chapter exercises.   Run:  nex exercises.nex
--
-- Uses the `books` array (Section 11.1) and the `filesystem` tree (Section 11.6).
-- ============================================================================

-- 1. All books by a given author.
function books_by_author(books: Array[Map[String, Any]], author: String): Array[Map[String, Any]] do
  result := []
  across books as book do
    if book.get("author") = author then
      result.add(book)
    end
  end
end

-- 2. Author -> array of that author's titles.
function invert_index(books: Array[Map[String, Any]]): Map[String, Array[String]] do
  result := {}
  across books as book do
    if convert book.get("author") to author: String then
      if convert book.get("title") to title: String then
        let titles: Array[String] := result.try_get(author, [])
        titles.add(title)
        result.set(author, titles)
      end
    end
  end
end

-- 3. Recursively count file nodes (type = "file").
function count_files(node: Map[String, Any]): Integer do
  result := 0
  if node.get("type") = "file" then
    result := 1
  end
  if convert node.get("children") to children: Array[Map[String, Any]] then
    across children as child do
      result := result + count_files(child)
    end
  end
end

-- 4. Maximum depth: a leaf (no children) has depth 0; otherwise 1 + max child depth.
function tree_depth(node: Map[String, Any]): Integer do
  result := 0
  if convert node.get("children") to children: Array[Map[String, Any]] then
    across children as child do
      let d: Integer := 1 + tree_depth(child)
      if d > result then
        result := d
      end
    end
  end
end

-- 5.* Names in depth-first order (a node before its children).
function flatten(node: Map[String, Any]): Array[String] do
  result := []
  if convert node.get("name") to name: String then
    result.add(name)
  end
  if convert node.get("children") to children: Array[Map[String, Any]] then
    across children as child do
      across flatten(child) as n do
        result.add(n)
      end
    end
  end
end

-- 5.* Only the leaf (file) names, depth-first.
function flatten_leaves(node: Map[String, Any]): Array[String] do
  result := []
  if node.get("type") = "file" then
    if convert node.get("name") to name: String then
      result.add(name)
    end
  end
  if convert node.get("children") to children: Array[Map[String, Any]] then
    across children as child do
      across flatten_leaves(child) as n do
        result.add(n)
      end
    end
  end
end

-- Section 11.10 "Iterating Over Your Own Types": a user-defined iterable.
-- An Interval generates an inclusive range on demand; it stores no array.
class Interval_Cursor
  create
    make(lo, hi: Integer) do current := lo  last := hi end
  feature
    current: Integer
    last: Integer
    start() do end
    item(): Integer do result := current end
    next() do current := current + 1 end
    at_end(): Boolean do result := current > last end
end

class Interval
  create
    make(lo, hi: Integer)
      require ordered: lo <= hi
      do low := lo  high := hi end
  feature
    low: Integer
    high: Integer
    cursor(): Interval_Cursor
      do result := create Interval_Cursor.make(low, high) end
end

-- Exercise 6: Countdown yields n, n-1, ..., 1 when iterated.
class Countdown_Cursor
  create
    make(start_at: Integer) do current := start_at end
  feature
    current: Integer
    start() do end
    item(): Integer do result := current end
    next() do current := current - 1 end
    at_end(): Boolean do result := current < 1 end
end

class Countdown
  create
    make(n: Integer)
      require positive: n > 0
      do top := n end
  feature
    top: Integer
    cursor(): Countdown_Cursor
      do result := create Countdown_Cursor.make(top) end
end

-- Exercise 7*: a Stack[G] (on top of Array[G]) made iterable top-to-bottom
-- WITHOUT exposing its underlying array. The cursor is the only window in.
class Stack_Cursor[G]
  create
    make(data: Array[G]) do items := data  pos := data.length - 1 end
  feature
    items: Array[G]
    pos: Integer
    start() do end
    item(): G do result := items.get(pos) end
    next() do pos := pos - 1 end
    at_end(): Boolean do result := pos < 0 end
end

class Stack[G]
  create
    make() do items := [] end
  feature
    items: Array[G]
    push(value: G) do items.add(value) end
    size(): Integer do result := items.length end
    cursor(): Stack_Cursor[G]
      do result := create Stack_Cursor[G].make(items) end
end

function show(arr: Array[String]): String do
  result := "["
  from
    let i: Integer := 0
  until
    i >= arr.length
  do
    if i > 0 then result := result + ", " end
    result := result + arr.get(i)
    i := i + 1
  end
  result := result + "]"
end

function main() do
  let c: Console := create Console

  let books: Array[Map[String, Any]] := [
    {"title": "Dune", "author": "Frank Herbert", "year": 1965},
    {"title": "Dune Messiah", "author": "Frank Herbert", "year": 1969},
    {"title": "Neuromancer", "author": "William Gibson", "year": 1984},
    {"title": "Foundation", "author": "Isaac Asimov", "year": 1951}
  ]

  let filesystem: Map[String, Any] := {
    "name": "root",
    "type": "dir",
    "children": [
      {
        "name": "documents",
        "type": "dir",
        "children": [
          {"name": "report.txt", "type": "file", "children": []},
          {"name": "notes.txt", "type": "file", "children": []}
        ]
      },
      {
        "name": "pictures",
        "type": "dir",
        "children": [
          {"name": "photo.jpg", "type": "file", "children": []}
        ]
      }
    ]
  }
  let single: Map[String, Any] := {"name": "lonely", "type": "file", "children": []}

  -- 1.
  let herbert: Array[Map[String, Any]] := books_by_author(books, "Frank Herbert")
  c.print_line("1. Frank Herbert wrote " + herbert.length.to_string + " of the listed books")  -- 2

  -- 2.
  let idx: Map[String, Array[String]] := invert_index(books)
  c.print_line("2. Frank Herbert titles -> " + show(idx.get("Frank Herbert")))
  c.print_line("2. Isaac Asimov titles  -> " + show(idx.get("Isaac Asimov")))

  -- 3.
  c.print_line("3. count_files(filesystem) = " + count_files(filesystem).to_string)   -- 3

  -- 4.
  c.print_line("4. tree_depth(filesystem) = " + tree_depth(filesystem).to_string +
               ", tree_depth(single) = " + tree_depth(single).to_string)              -- 2, 0

  -- 5.*
  c.print_line("5. flatten        = " + show(flatten(filesystem)))
  c.print_line("5. flatten_leaves = " + show(flatten_leaves(filesystem)))

  -- Section 11.10: a user-defined type used as the source for `across`.
  -- The loop variable arrives as Any (a custom cursor may yield any type), so a
  -- plain print works directly but arithmetic narrows it with `convert`.
  let week: Interval := create Interval.make(1, 7)
  let days: String := ""
  across week as day do
    days := days + day.to_string + " "
  end
  c.print_line("11.10 Interval(1..7)  = " + days.trim)              -- 1 2 3 4 5 6 7

  let total: Integer := 0
  across (create Interval.make(1, 100)) as n do
    if convert n to value: Integer then
      total := total + value
    end
  end
  c.print_line("11.10 sum 1..100      = " + total.to_string)        -- 5050

  -- 6. Countdown, iterated twice to show each `cursor` call is independent.
  let cd: Countdown := create Countdown.make(5)
  let first: String := ""
  across cd as k do first := first + k.to_string + " " end
  let again: String := ""
  across cd as k do again := again + k.to_string + " " end
  c.print_line("6. Countdown(5) twice = " + first.trim + " | " + again.trim)  -- 5 4 3 2 1 | 5 4 3 2 1

  -- 7.* Iterate a Stack[Integer] top-to-bottom and total it via `convert`.
  let st: Stack[Integer] := create Stack[Integer].make()
  st.push(10)
  st.push(20)
  st.push(30)
  let order: String := ""
  let sum: Integer := 0
  across st as e do
    order := order + e.to_string + " "
    if convert e to v: Integer then
      sum := sum + v
    end
  end
  c.print_line("7. Stack top->bottom  = " + order.trim + " (sum " + sum.to_string + ")")  -- 30 20 10 (sum 60)
end

main()
