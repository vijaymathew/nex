-- ============================================================================
-- Programming with Nex — Chapter 6: Functions
-- Solutions to the end-of-chapter exercises.   Run:  nex exercises.nex
-- ============================================================================

-- 1. Fahrenheit -> Kelvin:  (F - 32) * 5/9 + 273.15
function fahrenheit_to_kelvin(f: Real): Real do
  result := (f - 32.0) * 5.0 / 9.0 + 273.15
end

-- 2. Leap year: divisible by 4, but not by 100 unless also by 400.
function is_leap_year(year: Integer): Boolean do
  result := year % 4 = 0 and (year % 100 /= 0 or year % 400 = 0)
end

-- 3. Sum of the digits of a non-negative integer.
function digit_sum(n: Integer): Integer do
  result := 0
  from
    let m: Integer := n
  until
    m = 0
  do
    result := result + m % 10
    m := m / 10
  end
end

-- 4. min3 / max3, and range3 built from them (no duplicated logic).
function min3(a, b, c: Integer): Integer do
  result := a
  if b < result then result := b end
  if c < result then result := c end
end

function max3(a, b, c: Integer): Integer do
  result := a
  if b > result then result := b end
  if c > result then result := c end
end

function range3(a, b, c: Integer): Integer do
  result := max3(a, b, c) - min3(a, b, c)
end

function main() do
  let c: Console := create Console

  -- 1.
  c.print_line("1. 32F  in K = " + fahrenheit_to_kelvin(32.0).to_string)    -- 273.15
  c.print_line("1. 212F in K = " + fahrenheit_to_kelvin(212.0).to_string)   -- 373.15

  -- 2.
  c.print_line("2. 2000 leap? " + is_leap_year(2000).to_string)   -- true
  c.print_line("2. 1900 leap? " + is_leap_year(1900).to_string)   -- false
  c.print_line("2. 2024 leap? " + is_leap_year(2024).to_string)   -- true
  c.print_line("2. 2023 leap? " + is_leap_year(2023).to_string)   -- false

  -- 3.
  c.print_line("3. digit_sum(123) = " + digit_sum(123).to_string)   -- 6
  c.print_line("3. digit_sum(0)   = " + digit_sum(0).to_string)     -- 0

  -- 4.
  c.print_line("4. min3(4,2,7)=" + min3(4, 2, 7).to_string +
               " max3(4,2,7)=" + max3(4, 2, 7).to_string +
               " range3(4,2,7)=" + range3(4, 2, 7).to_string)       -- 2 7 5

  -- --------------------------------------------------------------------------
  -- 5.* A variable holding an anonymous function, reassigned to a different
  --     function. Functions are VALUES: the same call site `transform(v)` runs
  --     whatever function the variable currently holds. First doubling, then,
  --     after reassignment, squaring — same inputs, different behaviour.
  -- --------------------------------------------------------------------------
  let transform: Function := fn (n: Integer): Integer do result := n * 2 end
  c.print_line("5. doubling: " + transform(3).to_string + " " +
               transform(5).to_string + " " + transform(8).to_string)   -- 6 10 16
  transform := fn (n: Integer): Integer do result := n * n end
  c.print_line("5. squaring: " + transform(3).to_string + " " +
               transform(5).to_string + " " + transform(8).to_string)   -- 9 25 64
  c.print_line("5. -> a function is a value; the variable selects the behaviour.")
end

main()
