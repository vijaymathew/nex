class PlatformUtils
  note "Utility class with platform-specific implementations"

feature
  current_time_millis(): Integer
    note "Get current time in milliseconds"
  do
      result := 0
      with "java" do
        result := 42
      end
      with "javascript" do
        result := 99
      end
  end

  print_platform() do
      with "java" do
        print("Running on Java")
      end
      with "javascript" do
        print("Running on JavaScript")
      end
  end

  get_random(): Integer do
      result := 0
      with "java" do
        result := 1
      end
      with "javascript" do
        result := 2
      end
  end
end
