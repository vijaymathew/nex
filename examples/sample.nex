-- Sample Nex program demonstrating current syntax.
-- Includes inheritance, base-constructor call, and base-feature access.

class Account
feature
  balance: Decimal
  account_number: String
  is_active: Boolean

create
  make(b: Decimal, number: String) do
    balance := b
    account_number := number
    is_active := true
  end

feature
  deposit(amount: Decimal)
    require
      positive_amount: amount > 0.0
      active_account: is_active
    do
      balance := balance + amount
    ensure
      increased: balance = old balance + amount
    end

  withdraw(amount: Decimal)
    require
      positive_amount: amount > 0.0
      enough: balance >= amount
      active_account: is_active
    do
      balance := balance - amount
    ensure
      decreased: balance = old balance - amount
    end

  set_active(active: Boolean) do
    is_active := active
  end

  show() do
    print("Account ")
    print(account_number)
    print(" balance: ")
    print(balance)
  end

invariant
  non_negative_balance: balance >= 0.0
end

class Savings
inherit
  Account
feature
  interest_rate: Real

create
  make(b: Decimal, number: String, i: Real) do
    Account.make(b, number)
    interest_rate := i
  end

feature
  apply_interest() do
    balance := balance + (balance * interest_rate)
  end

  withdraw(amount: Decimal)
    require
      active_account: is_active
    do
      -- Base class feature access (similar to Java super.member)
      Account.withdraw(amount)
    end

  show() do
    print("Savings account: ")
    print(account_number)
    print(" base balance via Account.balance = ")
    print(Account.balance)
    print(", rate = ")
    print(interest_rate)
  end

invariant
  valid_rate: interest_rate >= 0.0 and interest_rate <= 1.0
end
