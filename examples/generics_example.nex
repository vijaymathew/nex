-- Generic Types Example
--
-- Parameterized classes:
--
--   class Box [T]                     one type parameter
--   class Pair [F, S]                 several
--   class Sorted_List [G -> Comparable]  constrained: G must conform to
--                                        Comparable, so the class body may
--                                        rely on `<` and `>` for a G
--
-- A generic class is written once and checked once; each instantiation
-- (Box [Integer], Box [String]) is a distinct type to the typechecker.
--
-- Run:  nex generics_example.nex

class Box [T]
  create
    make(v: T) do
      value := v
    end

  feature
    value: T

    get(): T do
      result := value
    end

    set(v: T) do
      value := v
    end
end

-- A generic class can inherit from an instantiation of another one.
class Logged_Box [T]
  inherit
    Box [T]

  create
    make(v: T) do
      Box.make(v)
      change_count := 0
    end

  feature
    change_count: Integer

    set(v: T) do
      Box.set(v)
      change_count := change_count + 1
    end

    changes(): Integer do
      result := change_count
    end
end

-- The type parameter flows into the backing array's type.
class Stack [G]
  create
    make(capacity: Integer)
      require
        positive: capacity > 0
      do
        items := []
        max_size := capacity
      end

  feature
    items: Array [G]
    max_size: Integer

    count(): Integer do
      result := items.length
    end

    is_empty(): Boolean do
      result := items.length = 0
    end

    push(item: G)
      require
        not_full: items.length < max_size
      do
        items.add(item)
      ensure
        not_empty: items.length > 0
      end

    pop(): G
      require
        not_empty: items.length > 0
      do
        result := items.get(items.length - 1)
        items.remove(items.length - 1)
      end

    peek(): G
      require
        not_empty: items.length > 0
      do
        result := items.get(items.length - 1)
      end
end

-- Constrained: G must conform to Comparable, which is what makes `>` legal
-- on values of type G inside this class.
class Sorted_List [G -> Comparable]
  create
    make() do
      items := []
    end

  feature
    items: Array [G]

    -- Insertion sort: walk to the first element larger than new_item.
    insert(new_item: G) do
      let pos: Integer := 0
      from
        let i: Integer := 0
      until
        i >= items.length
      do
        if items.get(i) > new_item then
          i := items.length
        else
          pos := i + 1
          i := i + 1
        end
      end
      items.add_at(pos, new_item)
    end

    max(): G
      require
        not_empty: items.length > 0
      do
        result := items.get(items.length - 1)
      end

    to_text(): String do
      result := ""
      from
        let i: Integer := 0
      until
        i >= items.length
      do
        if i > 0 then
          result := result + ", "
        end
        result := result + items.get(i).to_string
        i := i + 1
      end
    end
end

-- Two independent type parameters.
class Pair [F, S]
  create
    make(first_val: F, second_val: S) do
      first := first_val
      second := second_val
    end

  feature
    first: F
    second: S

    swap(): Pair [S, F] do
      result := create Pair.make(second, first)
    end
end

function main() do
  let c: Console := create Console

  -- 1. One class, two instantiations -- each with its own element type.
  c.print_line("1. Box [T]")
  let int_box: Box [Integer] := create Box.make(42)
  let str_box: Box [String] := create Box.make("hello")
  c.print_line("  Box [Integer] holds " + int_box.get.to_string)
  c.print_line("  Box [String]  holds " + str_box.get)
  int_box.set(99)
  c.print_line("  after set(99): " + int_box.get.to_string)

  -- 2. Inheriting from an instantiation, and redefining a feature.
  c.print_line("2. Logged_Box [T] inherit Box [T]")
  let logged: Logged_Box [String] := create Logged_Box.make("first")
  logged.set("second")
  logged.set("third")
  c.print_line("  value = " + logged.get + ", changes = " + logged.changes.to_string)

  -- 3. The type parameter reaches the backing array.
  c.print_line("3. Stack [G]")
  let s: Stack [Integer] := create Stack.make(10)
  s.push(1)
  s.push(2)
  s.push(3)
  c.print_line("  count = " + s.count.to_string + ", peek = " + s.peek.to_string)
  c.print_line("  pop   = " + s.pop.to_string + ", pop = " + s.pop.to_string)
  c.print_line("  is_empty = " + s.is_empty.to_string)

  -- 4. A constraint is what lets the class body use `>` on a G.
  c.print_line("4. Sorted_List [G -> Comparable]")
  let sorted: Sorted_List [Integer] := create Sorted_List.make
  sorted.insert(5)
  sorted.insert(2)
  sorted.insert(9)
  sorted.insert(1)
  sorted.insert(7)
  c.print_line("  sorted = " + sorted.to_text)
  c.print_line("  max    = " + sorted.max.to_string)

  let words: Sorted_List [String] := create Sorted_List.make
  words.insert("pear")
  words.insert("apple")
  words.insert("mango")
  c.print_line("  sorted = " + words.to_text)

  -- 5. Several parameters. F and S are unconstrained, so the class body can
  --    only move these values around -- it knows nothing about them. Anything
  --    type-specific happens here, where F and S are known.
  c.print_line("5. Pair [F, S]")
  let p: Pair [String, Integer] := create Pair.make("answer", 42)
  c.print_line("  (" + p.first + ", " + p.second.to_string + ")")
  let flipped: Pair [Integer, String] := p.swap
  c.print_line("  swapped: (" + flipped.first.to_string + ", " + flipped.second + ")")
end

main()
