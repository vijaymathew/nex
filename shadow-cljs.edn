{:source-paths ["src" "test"]
 :dependencies []
 :builds
 {:node
  {:target :node-library
   :output-to "target/nex.js"
   :exports {:evalNode nex.interpreter/eval-node
             :makeContext nex.interpreter/make-context
             :registerClass nex.interpreter/register-class}}

  :test
  {:target :node-test
   :output-to "target/test.js"
   :ns-regexp "-test$"
   :autorun true}

  ;; Cross-platform differential harness. Replays the corpus produced by
  ;; test/scripts/gen_platform_corpus.clj through the cljs interpreter and
  ;; compares against the JVM golden output.
  :platform-diff
  {:target :node-script
   :output-to "target/platform_diff.js"
   :main nex.platform-diff/-main}}}
