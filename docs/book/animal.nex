function has_forward_failed(t: Turtle): Boolean do
  let hw: Integer := t.surface.vw / 2
  let hh: Integer := t.surface.vh / 2  
  result := (t.xpos <= -hw) or (t.ypos <= -hh) or (t.xpos >= hw) or (t.ypos >= hh)
end

function check_forward(t: Turtle, distance: Integer): Boolean do
  let prev_x: Integer := t.xpos
  let prev_y: Integer := t.ypos
  t.penup
  t.hide
  t.forward(distance)
  let stuck: Boolean := has_forward_failed(t)
  t.goto(prev_x, prev_y)
  t.pendown
  t.show
  if not(stuck) then t.forward(distance) end
  result := stuck
end

function wriggle(t: Turtle) do
  from let stuck := true
  until not(stuck) do
    t.right(1)
    stuck := check_forward(t, 1)
  end
end

function random_move(t: Turtle, d1: Integer, d2: Integer, a1: Integer, a2: Integer) do
  repeat 150 do
    t.left((a2).pick + a1)
    let stuck: Boolean := check_forward(t, (d2).pick + d1)
    if stuck then wriggle(t) end
  end
end
