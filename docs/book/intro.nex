function turtle(title: String): Turtle do
  let win: Window := create Window.with_title(title)
  win.show()

  let t := create Turtle.on_window(win)
  t.speed(6)
  t.pensize(3)
  result := t
end

function square_piece(t: Turtle, size: Integer) do
  t.forward(size)
  t.right(90)
end

function square(t: Turtle, size: Integer) do
  repeat 4 do
    square_piece(t, size)
  end
end

function rectangle(t: Turtle, side1: Integer, side2: Integer) do
  repeat 2 do
    square_piece(t, side1)
    square_piece(t, side2)
  end
end
