class Point inherit Any
  feature
    x: Integer
    y: Integer
  create
    make(a: Integer, b: Integer) do
      x := a
      y := b
    end
end

let s: Set[Point] := #{create Point.make(1, 2), create Point.make(1, 2), create Point.make(3, 4)}
print(s.size)
print(s.contains(create Point.make(1, 2)))
print(s.contains(create Point.make(9, 9)))

let a: Set[Integer] := #{1, 2, 3}
let b: Set[Integer] := #{2, 3, 4}
print(a.union(b).size)
print(a.intersection(b).size)
print(a.difference(b).size)
